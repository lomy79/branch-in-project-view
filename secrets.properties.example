# Copy this file to `secrets.properties` (git-ignored) and fill in the values.
# Used by ./publish.sh — quote values that contain special characters.

# Passphrase chosen when generating private.pem
PRIVATE_KEY_PASSWORD='your-passphrase-here'

# JetBrains Marketplace permanent token (only needed for ./publish.sh publish)
PUBLISH_TOKEN='your-marketplace-token-here'
