<idea-plugin>
    <id>io.github.lomy79.branchinprojectview</id>
    <name>Branch in Project View</name>
    <version>0.2.0</version>
    <vendor email="aaresu@gmail.com" url="https://github.com/lomy79/branch-in-project-view">Andrea Aresu</vendor>

    <description><![CDATA[
        Shows the current git branch instead of the path (location string)
        next to each module / content root in the <b>Project</b> tool window.<br>
        <ul>
            <li>Branch colored by name: green on <code>main</code>/<code>master</code>, orange otherwise.</li>
            <li>↑ / ↓ arrows for commits to push / pull vs origin.</li>
            <li>An amber ● marker when the working tree has uncommitted changes.</li>
            <li>Click the branch text (or use the context menu) to switch branch via the native Git popup.</li>
        </ul>
        In monorepos each module shows the branch of its own repository.
    ]]></description>

    <change-notes><![CDATA[
        <b>0.2.0</b>
        <ul>
            <li>The branch label now also appears in the <b>Scopes</b> view (and other panes),
                not only in the <b>Project</b> view.</li>
            <li>Clicking the branch label opens the checkout popup in those panes too.</li>
        </ul>
        <b>0.1.0</b>
        <ul>
            <li>Initial release.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <treeStructureProvider
            implementation="io.github.lomy79.branchinprojectview.BranchTreeStructureProvider"/>
        <projectViewNodeDecorator
            implementation="io.github.lomy79.branchinprojectview.BranchNodeDecorator"/>
        <postStartupActivity
            implementation="io.github.lomy79.branchinprojectview.BranchClickActivity"/>
    </extensions>

    <projectListeners>
        <!-- Repo state change (e.g. checking out another branch). -->
        <listener class="io.github.lomy79.branchinprojectview.BranchChangeRefreshListener"
                  topic="git4idea.repo.GitRepositoryChangeListener"/>
        <!-- Git repos discovery/update (async registration at startup). -->
        <listener class="io.github.lomy79.branchinprojectview.BranchChangeRefreshListener"
                  topic="com.intellij.dvcs.repo.VcsRepositoryMappingListener"/>
        <!-- Incoming/outgoing info vs origin updates (the arrows). -->
        <listener class="io.github.lomy79.branchinprojectview.BranchChangeRefreshListener"
                  topic="git4idea.branch.GitBranchIncomingOutgoingManager$GitIncomingOutgoingListener"/>
        <!-- Local change list updates (the ● dirty working tree marker). -->
        <listener class="io.github.lomy79.branchinprojectview.BranchChangeRefreshListener"
                  topic="com.intellij.openapi.vcs.changes.ChangeListListener"/>
    </projectListeners>

    <actions>
        <action id="io.github.lomy79.branchinprojectview.ShowBranches"
                class="io.github.lomy79.branchinprojectview.ShowBranchesAction"
                text="Git Branches…"
                description="Opens the git branches popup for the selected module"
                icon="AllIcons.Vcs.Branch">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
